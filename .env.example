# Environment Variables - Internal AI Marketing Team
#
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# .env is already listed in .gitignore.

# ---------------------------------------------------------
# META ADS
# Get from: developers.facebook.com/apps → your app → Access Token Tool
# Permissions needed: ads_management, ads_read, pages_manage_ads, pages_read_engagement
# ---------------------------------------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_long_lived_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id

# ---------------------------------------------------------
# GOHIGHLEVEL
# Get from: GHL Settings → Integrations → API Keys
# Use Location API key (not Agency key) for a sub-account
# ---------------------------------------------------------
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id

# ---------------------------------------------------------
# GOOGLE (Shared OAuth - used by Analytics, Drive, Gmail, Calendar)
# Get from: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Enable APIs: Analytics Data API, Drive API, Gmail API, Calendar API
# ---------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ---------------------------------------------------------
# GOOGLE ANALYTICS
# Get from: analytics.google.com → Admin → Property Settings
# Format: numbers only, no 'G-' prefix for GA4 property ID
# ---------------------------------------------------------
GA4_PROPERTY_ID=your_ga4_property_id

# ---------------------------------------------------------
# AIRTABLE
# Get from: airtable.com/create/tokens
# Scopes: data.records:read, data.records:write, schema.bases:read
# ---------------------------------------------------------
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id

# ---------------------------------------------------------
# N8N
# Get from: your n8n instance → Settings → API
# ---------------------------------------------------------
N8N_API_KEY=your_n8n_api_key
N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud

# ---------------------------------------------------------
# APIFY (Market Research)
# Get from: console.apify.com → Settings → API & Integrations
# ---------------------------------------------------------
APIFY_TOKEN=your_apify_api_token

# ---------------------------------------------------------
# SLACK
# Get from: api.slack.com/apps → your app → OAuth & Permissions → Bot Token
# Scopes: channels:read, channels:history, chat:write, users:read
# ---------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=your_default_channel_id

# ---------------------------------------------------------
# SUPABASE (if used instead of or alongside Airtable)
# Get from: supabase.com → your project → Settings → API
# ---------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------------------------------------------------------
# GITHUB
# Get from: github.com → Settings → Developer Settings → Personal access tokens
# Scopes: repo (for private repos) or public_repo (for public only)
# ---------------------------------------------------------
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat
