# Environment files - never commit these
.env
.env.local
.env.production
.env.*.local

# Claude Code MCP config with live credentials - use mcp-configs/*.json templates instead
.claude/mcp.json

# Claude Code session memory and project state - not for version control
.claude/projects/

# Claude Code user settings (if created with real values)
.claude/settings.json

# OS files
.DS_Store
Thumbs.db

# Node modules if any tools are installed locally
node_modules/
package-lock.json

# Logs
*.log
npm-debug.log*

# Uploads and extracted files that should not be in version control
# (comment out if you want to include these)
# uploads/

# Temporary files
*.tmp
*.temp
