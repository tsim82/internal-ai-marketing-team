# MCP Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# All values below are placeholders only.

# n8n
N8N_API_KEY=your_n8n_api_key_here
N8N_HOST_URL=https://your-n8n-instance.com

# Airtable
AIRTABLE_API_KEY=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Supabase
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Apify
APIFY_API_KEY=your_apify_api_key_here

# Google (shared OAuth for Drive, Sheets, Analytics, Search Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Google Analytics GA4
GA4_PROPERTY_ID=your_ga4_property_id_here

# Meta Ads
META_ACCESS_TOKEN=your_meta_long_lived_access_token_here
META_AD_ACCOUNT_ID=act_your_account_id_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_here

# GoHighLevel
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_location_id_here

# Canva
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here

# Remotion (AWS Lambda rendering)
REMOTION_AWS_ACCESS_KEY_ID=your_aws_access_key_here
REMOTION_AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-placeholder

# HeyGen
HEYGEN_API_KEY=your_heygen_api_key_here

# YouTube
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# Facebook / Instagram
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_PAGE_ID=your_page_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_ID=your_linkedin_person_urn_here

# TikTok
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Gmail
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
